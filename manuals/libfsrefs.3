.Dd June 14, 2026
.Dt LIBFSREFS 3
.Os
.Sh NAME
.Nm libfsrefs.h
.Nd Library to access the Resiliant File System (ReFS) format
.Sh SYNOPSIS
.In libfsrefs.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libfsrefs_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libfsrefs_get_access_flags_read
.Fa "void"
.Fc
.fi
.nf
.Ft int
