.Fa "libfsrefs_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfsrefs_check_volume_signature
.Fa "const char *filename"
.Fa "libfsrefs_error_t **error"
.Fc
.fi
.Pp
Available when compiled with wide character string support:
.nf
.Ft int
.Fo libfsrefs_check_volume_signature_wide
.Fa "const wchar_t *filename"
.Fa "libfsrefs_error_t **error"
.Fc
.fi
.Pp
Available when compiled with libbfio support:
.nf
.Ft int
.Fo libfsrefs_check_volume_signature_file_io_handle
.Fa "libbfio_handle_t *file_io_handle"
.Fa "libfsrefs_error_t **error"
.Fc
.fi
